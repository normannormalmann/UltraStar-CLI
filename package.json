{
  "name": "ultrastar",
  "description": "Download songs from UltraStar biggest database",
  "version": "1.2.0",
  "type": "module",
  "private": true,
  "main": "out/main/index.js",
  "keywords": [
    "ultrastar",
    "cli",
    "download",
    "songs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/martiinii/UltraScrap-cli"
  },
  "license": "MIT",
  "homepage": "https://github.com/martiinii/UltraScrap-cli",
  "trustedDependencies": ["electron"],
  "patchedDependencies": {
    "fstream@1.0.12": "patches/fstream@1.0.12.patch"
  },
  "scripts": {
    "build": "bun run --cwd src build.ts",
    "start": "bun run src/index.tsx",
    "test": "bun test src",
    "desktop:dev": "electron-vite dev",
    "desktop:build": "electron-vite build",
    "desktop:dist": "electron-vite build && electron-builder --win",
    "test:e2e": "electron-vite build && playwright test",
    "format": "biome format --write .",
    "clean": "git clean -xdf .turbo build",
    "lint": "biome lint --write .",
    "bump": "bumpp"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.4",
    "@playwright/test": "latest",
    "@types/bun": "latest",
    "@types/react": "^19.1.9",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "bumpp": "^10.2.2",
    "chalk": "^5.5.0",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "latest",
    "extract-zip": "latest",
    "pretty-bytes": "^7.0.0",
    "react-devtools-core": "^6.1.5",
    "tinyglobby": "^0.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "effect": "^3.17.7",
    "env-paths": "^3.0.0",
    "exceljs": "^4.4.0",
    "ink": "^6.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
